# ─── LLM (policy compiler + intent reconciler) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Coinbase CDP server wallet (CDP SDK v2) ──────────────────────────────────
CDP_API_KEY_ID=...
CDP_API_KEY_SECRET=...
CDP_WALLET_SECRET=...
# Name of the CDP-managed EVM account agentctl should use
CDP_ACCOUNT_NAME=agentctl-agent

# ─── x402 ─────────────────────────────────────────────────────────────────────
# Base Sepolia testnet facilitator (mainnet uses the CDP facilitator)
X402_FACILITATOR_URL=https://x402.org/facilitator

# ─── RPC (balance checks + anchor commits) ────────────────────────────────────
RPC_BASE_SEPOLIA=https://sepolia.base.org

# ─── Audit ────────────────────────────────────────────────────────────────────
AUDIT_STORE=sqlite
AUDIT_DB_PATH=./agentctl.sqlite
AUDIT_ANCHOR_ADDRESS=0x...
AUDIT_ANCHOR_INTERVAL_MS=3600000
# Key that pays gas for hourly Merkle-root commits (testnet key only)
ANCHOR_COMMITTER_KEY=0x...

# ─── Local-dev wallet (raw viem adapter; NEVER use a real key) ────────────────
AGENT_PRIVATE_KEY=0x...

# ─── Reference: Base Sepolia USDC ─────────────────────────────────────────────
# USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
