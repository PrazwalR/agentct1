{
  "name": "@agentctl/core",
  "version": "0.1.0",
  "description": "Policy & observability layer for autonomous AI agent payments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./x402": {
      "types": "./dist/x402/index.d.ts",
      "default": "./dist/x402/index.js"
    },
    "./adapters/cdp": {
      "types": "./dist/adapters/cdp.d.ts",
      "default": "./dist/adapters/cdp.js"
    },
    "./adapters/viem": {
      "types": "./dist/adapters/viem.d.ts",
      "default": "./dist/adapters/viem.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@x402/core": "^2.16.0",
    "@x402/evm": "^2.16.0",
    "@x402/fetch": "^2.16.0",
    "@x402/svm": "^2.17.0",
    "better-sqlite3": "^12.11.1",
    "viem": "^2.53.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.7.1",
    "@coinbase/cdp-sdk": "^1.51.2",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@privy-io/server-auth": "^1.32.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "pg-mem": "^3.0.14"
  },
  "peerDependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.7.1",
    "@coinbase/cdp-sdk": "^1.51.2",
    "@privy-io/server-auth": "^1.32.5",
    "pg": "^8.22.0"
  },
  "peerDependenciesMeta": {
    "@circle-fin/developer-controlled-wallets": {
      "optional": true
    },
    "@coinbase/cdp-sdk": {
      "optional": true
    },
    "@privy-io/server-auth": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  }
}
